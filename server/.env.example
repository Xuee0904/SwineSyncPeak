# ─── SwineSync Node.js API — Environment Variables ───────────────────────────
# Copy this file to .env and fill in your real Supabase credentials.
# NEVER commit .env to version control.

# Your Supabase project URL (found in: Project Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Service Role key (found in: Project Settings → API → service_role)
# Use service_role (not anon) so server-side queries bypass Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Express server port (default: 3001)
PORT=3001
